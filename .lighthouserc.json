{
  "ci": {
    "collect": {
      "staticDistDir": "docs",
      "url": [
        "http://localhost/index.html"
      ],
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": "--headless=new --disable-dev-shm-usage --user-data-dir=.lighthouseci/chrome-profile"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.9
          }
        ],
        "largest-contentful-paint": [
          "warn",
          {
            "maxNumericValue": 2500
          }
        ],
        "interaction-to-next-paint": [
          "warn",
          {
            "maxNumericValue": 200
          }
        ],
        "cumulative-layout-shift": [
          "warn",
          {
            "maxNumericValue": 0.1
          }
        ]
      },
      "aggregationMethod": "median-run"
    }
  }
}
